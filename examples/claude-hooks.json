{
  "description": "kbd-signal lifecycle notifications for Claude Code. Merge the hooks object into your user-scope settings.json (do not overwrite existing hooks).",
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "kbd-signal hook claude",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "kbd-signal hook claude",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "kbd-signal hook claude",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "kbd-signal hook claude",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
